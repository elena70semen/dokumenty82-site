D82_FORM_HOST=127.0.0.1
D82_FORM_PORT=8097
D82_LEADS_DIR=/var/lib/dokumenty82-leads
D82_MAX_REQUEST_MB=25
D82_MAX_UPLOAD_MB=20
D82_MAX_FILES=6
D82_ACCEPT_LOCAL_ONLY=0

# AmoCRM account. Example: mycompany or mycompany.amocrm.ru
AMO_SUBDOMAIN=

# External integration / OAuth.
# Redirect URI in amoCRM:
# https://dokumenty82.ru/api/amo/oauth/callback
# Disconnect hook:
# https://dokumenty82.ru/api/amo/oauth/disconnect
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=https://dokumenty82.ru/api/amo/oauth/callback
AMO_TOKEN_PATH=/var/lib/dokumenty82-leads/amo-oauth-token.json

# Only needed if using amoCRM external webhook that sends client_id/client_secret.
# Use a long random value and pass it as the external integration state.
AMO_EXTERNAL_STATE=

# Legacy fallback for a manually managed bearer token. Prefer OAuth above.
AMO_ACCESS_TOKEN=

# Optional routing inside amoCRM.
AMO_PIPELINE_ID=
AMO_STATUS_ID=
AMO_RESPONSIBLE_USER_ID=
AMO_TAGS=site,razbor-situacii

# Optional file upload into amoCRM Files API.
# Requires the integration scope "Доступ к файлам".
AMO_ATTACH_FILES=0
AMO_DRIVE_URL=
